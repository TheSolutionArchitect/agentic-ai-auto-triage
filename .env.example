# LLM Providers
OPENAI_API_KEY=sk-...
ANTHROPIC_API_KEY=sk-ant-...

# MCP Tool Tokens
GITHUB_MCP_TOKEN=ghp_...
ATLASSIAN_MCP_TOKEN=...
SLACK_MCP_TOKEN=xoxb-...
TFE_TOKEN=...

# State and Checkpointing
LANGGRAPH_POSTGRES_URL=postgresql://user:pass@localhost:5432/langgraph

# Evidence Store (S3)
EVIDENCE_BUCKET=my-terraform-devops-evidence
EVIDENCE_KMS_KEY_ID=arn:aws:kms:us-east-1:123456789:key/...

# Optional: GitHub Webhook Secret (for HMAC validation)
GITHUB_WEBHOOK_SECRET=...

# Optional: Vault integration (leave blank to use env vars directly)
# VAULT_ADDR=https://vault.example.com
# VAULT_TOKEN=hvs.xxx
# VAULT_ROLE=agentic-terraform-devops

# Optional: AWS Secrets Manager (leave blank to use env vars directly)
# AWS_REGION=us-east-1
# SECRETS_MANAGER_PREFIX=/agentic-terraform-devops/

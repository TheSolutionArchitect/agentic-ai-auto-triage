{
  "name": "iac_scanner",
  "type": "mcp",
  "server": {
    "transport": "stdio",
    "command": "iac-scanner-mcp",
    "args": ["--config", "scanner-config.yaml"],
    "env": {}
  },
  "scanners": ["checkov", "tfsec", "terrascan"],
  "severity_map": {
    "CRITICAL": "HIGH",
    "HIGH": "HIGH",
    "MEDIUM": "MEDIUM",
    "LOW": "LOW",
    "INFO": "LOW"
  },
  "allowed_tools": [
    "scanner.scan_files",
    "scanner.scan_directory",
    "scanner.get_results",
    "scanner.get_rule_details"
  ],
  "disallowed_tools": [],
  "fail_on_unavailable": {
    "prod": true,
    "stage": true,
    "test": true,
    "dev": false
  }
}

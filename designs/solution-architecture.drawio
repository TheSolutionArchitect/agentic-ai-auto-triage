        <mxCell id="IWc9zJM8tDhvkjJ2dRjy-19" parent="1" style="text;html=1;whiteSpace=wrap;overflow=hidden;rounded=0;" value="&lt;h1 style=&quot;margin-top: 0px;&quot;&gt;Auto Fix Agent (GitHub)&lt;/h1&gt;&lt;p&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;span style=&quot;font-size: 18px;&quot;&gt;Automatically fix the code where the confidence score is greater than 0.6, and the severity is MEDIUM or LOW.&amp;nbsp;&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;span style=&quot;font-size: 18px;&quot;&gt;Create a report for the fixed and unresolved items.&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="192" width="440" x="1610" y="478" as="geometry" />
        </mxCell>
        <mxCell id="IWc9zJM8tDhvkjJ2dRjy-20" parent="1" style="text;whiteSpace=wrap;fontSize=18;align=center;" value="Set severity and confidence scores for each finding.&#xa;Severity scores are defined by HIGH, MEDIUM, and LOW. The confidence score is between 0 and 1." vertex="1">

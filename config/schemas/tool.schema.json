{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "tool.schema.json",
  "title": "Tool Config",
  "type": "object",
  "required": ["name", "type", "server", "allowed_tools"],
  "additionalProperties": true,
  "properties": {
    "name": { "type": "string" },
    "type": { "type": "string", "enum": ["mcp"] },
    "server": {
      "type": "object",
      "required": ["transport"],
      "properties": {
        "transport": { "type": "string", "enum": ["streamable_http", "stdio", "sse"] },
        "url": { "type": "string" },
        "command": { "type": "string" },
        "args": { "type": "array", "items": { "type": "string" } },
        "env": { "type": "object", "additionalProperties": { "type": "string" } },
        "auth": {
          "type": "object",
          "properties": {
            "type": { "type": "string", "enum": ["bearer", "oauth2", "oauth2_or_token", "none"] },
            "token_env": { "type": "string" }
          }
        }
      }
    },
    "allowed_tools": {
      "type": "array",
      "items": { "type": "string" },
      "minItems": 1
    },
    "disallowed_tools": {
      "type": "array",
      "items": { "type": "string" }
    }
  }
}
